@page
@model SignupModel
@{
    ViewData["Title"] = "Sign Up";
    Layout = null; // standalone page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - CSV Processor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(to right, #d9fdd3, #b8eacb); /* standard neutral background */
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .signup-card {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            width: 100%;
            max-width: 400px;
        }

            .signup-card h2 {
                text-align: center;
                margin-bottom: 30px;
                font-weight: bold;
            }

        .form-control:focus {
            box-shadow: none;
            border-color: #4e54c8;
        }

        .btn-success {
            background-color: #28a745;
            border-color: #28a745;
        }

            .btn-success:hover {
                background-color: #218838;
                border-color: #218838;
            }

        .message {
            margin-top: 10px;
            text-align: center;
            color: red;
            font-weight: 500;
        }

        .login-link {
            text-align: center;
            margin-top: 15px;
        }
    </style>
</head>
<body>
    <div class="signup-card">
        <h2>Create Account</h2>

        <form method="post">
            <div class="mb-3">
                <label asp-for="Username" class="form-label">Username</label>
                <input asp-for="Username" class="form-control" placeholder="Enter username" required />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" required />
            </div>

            <button type="submit" class="btn btn-success w-100">Sign Up</button>

            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="message">@Model.Message</div>
            }

            <div class="login-link">
                <span>Already have an account? </span>
                <a href="/Login">Login here</a>
            </div>
        </form>
    </div>
</body>
</html>
